# Copy to .env and adjust. Do not commit .env.
# Infrastructure stack (Traefik + Socket Proxy)

# Paths
DOCKERDIR=/opt/docker
# 容器運行時資料路徑（不版控，例如資料庫、快取等）
DATADIR=/mnt/raid1

# Timezone
TZ=Asia/Taipei

# Trusted IPs for X-Forwarded-* (e.g. Cloudflare, LAN). Comma-separated CIDR.
LOCAL_IPS=127.0.0.1/32,10.0.0.0/8,192.168.0.0/16,172.16.0.0/12
# Optional: when using Cloudflare proxy - https://www.cloudflare.com/ips/
CLOUDFLARE_IPS=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22

# Domain for Traefik and TLS (e.g. example.com). Dashboard: https://traefik.<DOMAINNAME_1>
DOMAINNAME_1=example.com

# Traefik dashboard port on host (container uses 8080)
TRAEFIK_PORT=8080

# Google OAuth Client ID
GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
# Google OAuth Client Secret 透過 secrets/google_oauth_client_secret 管理，不要放在 .env

# Pi-hole Host IP (用於 DNS 查詢與固定 IP 分配，建議與主機 IP 一致)
HOST_IP=192.168.x.x

# Media stack
# PUID / PGID - 執行容器的使用者/群組 ID（用 `id` 指令查看）
PUID=1000
PGID=1000

# Minecraft Java Edition server (compose/apps/minecraft.yml) - Velocity proxy + Fabric backend
# 玩家進 Velocity 做正版驗證，後端 Fabric 為 offline-mode 並由 FabricProxy-Lite 驗證 forwarding secret。
# Forwarding secret 由 secrets/velocity_forwarding_secret 提供（兩端共用，請勿提交）。
MINECRAFT_VERSION=1.21.11
MINECRAFT_TYPE=FABRIC
MINECRAFT_PORT=25565
MINECRAFT_MEMORY=2G
# Fabric 後端模組（逗號分隔；務必包含 fabricproxy-lite，否則 modern forwarding 會失效）
# MINECRAFT_MODRINTH_MODS=fabric-api,lithium,ferrite-core,krypton,c2me-fabric,fabricproxy-lite,...
# MINECRAFT_IMAGE_TAG=latest

# Velocity proxy（compose/apps/minecraft.yml）
# itzg/mc-proxy 映像標籤；版本鎖定使用 VELOCITY_VERSION
# VELOCITY_IMAGE_TAG=latest
VELOCITY_VERSION=latest
VELOCITY_MEMORY=512M
# Compose deploy.resources 上限（給 Prometheus/cAdvisor 看）
# VELOCITY_MEMORY_LIMIT=768m
# VELOCITY_CPU_LIMIT=1.0

# Home Assistant (compose/apps/home-assistant.yml) — 映像標籤見 https://github.com/orgs/home-assistant/packages/container/home-assistant
HOMEASSISTANT_VERSION=2026.4.4

# Kavita (compose/apps/kavita.yml) — 數位書庫；映像標籤見 https://github.com/kareadita/kavita/pkgs/container/kavita
# KAVITA_VERSION=latest

# Home stack - QuestDB (compose/homestack/questdb.yml) — CPU 上限（寫入尖峰時避免過度節流）
# QUESTDB_CPU_LIMIT=4.0

# Home stack - NATS Server (compose/homestack/nats.yml)
# NATS 版本標籤
NATS_VERSION=2.12.6-alpine