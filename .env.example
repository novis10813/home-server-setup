# Copy to .env and adjust. Do not commit .env.
# Infrastructure stack (Traefik + Socket Proxy)

# Paths
DOCKERDIR=/opt/docker
# 容器運行時資料路徑（不版控，例如資料庫、快取等）
DATADIR=/mnt/raid1

# Timezone
TZ=Asia/Taipei

# Trusted IPs for X-Forwarded-* (e.g. Cloudflare, LAN). Comma-separated CIDR.
LOCAL_IPS=127.0.0.1/32,10.0.0.0/8,192.168.0.0/16,172.16.0.0/12
# Optional: when using Cloudflare proxy - https://www.cloudflare.com/ips/
CLOUDFLARE_IPS=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22

# Domain for Traefik and TLS (e.g. example.com). Dashboard: https://traefik.<DOMAINNAME_1>
DOMAINNAME_1=example.com

# Traefik dashboard port on host (container uses 8080)
TRAEFIK_PORT=8080

# Google OAuth Client ID
GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
# Google OAuth Client Secret 透過 secrets/google_oauth_client_secret 管理，不要放在 .env

# Pi-hole Host IP (用於 DNS 查詢與固定 IP 分配，建議與主機 IP 一致)
HOST_IP=192.168.x.x

# Media stack
# PUID / PGID - 執行容器的使用者/群組 ID（用 `id` 指令查看）
PUID=1000
PGID=1000

# Minecraft Java Edition server (compose/apps/minecraft.yml) - Fabric + 效能模組
MINECRAFT_VERSION=1.21.4
MINECRAFT_TYPE=FABRIC
MINECRAFT_PORT=25565
MINECRAFT_MEMORY=2G
# 效能模組（逗號分隔，留空則用 compose 預設）。預設：fabric-api,lithium,ferrite-core,krypton,c2me-fabric,modernfix,lazydfu,alternate-current
# MINECRAFT_MODRINTH_MODS=fabric-api,lithium,ferrite-core,krypton,c2me-fabric,modernfix,lazydfu,alternate-current
# MINECRAFT_IMAGE_TAG=latest
